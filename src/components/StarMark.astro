---
interface Props { size?: number; orbital?: boolean; }
const { size = 34, orbital = false } = Astro.props;
---
<span class:list={["star-wrap", { orbital }]} style={`--star-size:${size}px`} aria-hidden="true">
  {orbital && <span class="orbit orbit-one"></span>}
  {orbital && <span class="orbit orbit-two"></span>}
  <svg viewBox="0 0 32 32" role="presentation">
    <defs>
      <linearGradient id="star-gold" x1="4" y1="3" x2="28" y2="29" gradientUnits="userSpaceOnUse">
        <stop stop-color="#f2d98a"/><stop offset=".5" stop-color="#d9b24c"/><stop offset="1" stop-color="#b07e22"/>
      </linearGradient>
    </defs>
    <path fill-rule="evenodd" fill="url(#star-gold)" d="M16 1Q20.5 11.5 31 16Q20.5 20.5 16 31Q11.5 20.5 1 16Q11.5 11.5 16 1Zm0 4.4Q18.4 13.6 26.6 16Q18.4 18.4 16 26.6Q13.6 18.4 5.4 16Q13.6 13.6 16 5.4Z"/>
    <path fill="url(#star-gold)" d="M16 11.4Q16.8 15.2 20.6 16Q16.8 16.8 16 20.6Q15.2 16.8 11.4 16Q15.2 15.2 16 11.4Z"/>
  </svg>
</span>

<style>
  .star-wrap { display: inline-grid; place-items: center; width: var(--star-size); height: var(--star-size); position: relative; flex: none; }
  svg { width: 100%; height: 100%; filter: drop-shadow(0 0 14px rgba(217,178,76,.22)); animation: star-breathe 4.5s ease-in-out infinite; }
  .orbital { width: min(31vw, 390px); height: min(31vw, 390px); }
  .orbital svg { width: 31%; height: 31%; z-index: 2; }
  .orbit { position: absolute; border: 1px solid rgba(201,162,75,.28); border-radius: 50%; inset: 19%; }
  .orbit::before, .orbit::after { content:""; position:absolute; background:rgba(201,162,75,.35); }
  .orbit::before { width:1px; height:160%; left:50%; top:-30%; }
  .orbit::after { height:1px; width:160%; top:50%; left:-30%; }
  .orbit-two { inset: 6%; border-color: rgba(91,140,255,.12); border-style: dashed; animation: orbit-turn 48s linear infinite; }
  @keyframes star-breathe { 50% { opacity:.78; transform:scale(.97); } }
  @keyframes orbit-turn { to { transform:rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { svg, .orbit-two { animation:none; } }
</style>
